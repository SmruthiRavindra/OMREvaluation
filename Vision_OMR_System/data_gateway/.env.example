# Data Gateway environment configuration
# Copy this file to .env and fill in your values.

PORT=3000
FASTAPI_URL=http://localhost:8000

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=omr_db
PGUSER=omr_user
PGPASSWORD=your_password_here
PGSSL=false

# Pool settings
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONN_TIMEOUT_MS=5000
